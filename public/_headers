# ─────────────────────────────────────────────────────────────────
# Public JSON API — catch-all for shared non-tier headers.
# Tier-specific headers (X-API-Tier, X-PPC-Suggested-Price) live on the
# specific rules above so we don't stack duplicate values. Endpoints with
# no specific rule fall through to this catch-all and default to free-core
# (documented in llms.txt and /api-terms).
# ─────────────────────────────────────────────────────────────────

/api/v1/*
  Cache-Control: public, max-age=21600, s-maxage=21600, stale-while-revalidate=86400
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, HEAD, OPTIONS
  Access-Control-Allow-Headers: Content-Type
  Access-Control-Max-Age: 86400
  X-Commercial-License: https://holdlens.com/api-terms
  X-Data-License-URL: https://holdlens.com/api-terms
  X-AI-Integration-Contact: https://holdlens.com/for-ai
  X-Attribution-Required: cite holdlens.com
  Link: <https://holdlens.com/api-terms>; rel="license", <https://holdlens.com/for-ai>; rel="help"

# ─────────────────────────────────────────────────────────────────
# llms.txt + robots.txt — discovery surfaces
# ─────────────────────────────────────────────────────────────────

/llms.txt
  Cache-Control: public, max-age=3600, s-maxage=3600
  Content-Type: text/plain; charset=utf-8
  X-Commercial-License: https://holdlens.com/api-terms

/robots.txt
  Cache-Control: public, max-age=3600, s-maxage=3600
  Content-Type: text/plain; charset=utf-8

/ads.txt
  Cache-Control: public, max-age=86400, s-maxage=86400
  Content-Type: text/plain; charset=utf-8

/feed.xml
  Cache-Control: public, max-age=3600, s-maxage=3600
  Content-Type: application/rss+xml; charset=utf-8

# ─────────────────────────────────────────────────────────────────
# OG images — long cache
# ─────────────────────────────────────────────────────────────────

/og/*
  Cache-Control: public, max-age=604800, s-maxage=604800, immutable

/_next/static/*
  Cache-Control: public, max-age=31536000, s-maxage=31536000, immutable

# ─────────────────────────────────────────────────────────────────
# Static HTML pages — edge cache so repeat visits hit CF instead of
# origin. 5-min edge + 1-hour stale-while-revalidate = cheap safety
# net (stale served while CF revalidates in the background). Content
# is rebuilt on every deploy so max 5 min between deploy + fresh html.
# Dynamic feeds (/activity, /this-week, /biggest-*) override below
# with tighter TTLs.
# ─────────────────────────────────────────────────────────────────

/
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/signal/*
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/investor/*
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/ticker/*
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/learn/*
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800

/api/
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400

/for-ai/
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400

/api-terms/
  Cache-Control: public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400

/today/
  Cache-Control: public, max-age=300, s-maxage=300, stale-while-revalidate=3600
  X-Content-Revision: daily-eod

# ─────────────────────────────────────────────────────────────────
# Security + commercial-license headers — all pages
# ─────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────
# Agent-discovery .well-known surfaces — serve correct Content-Type
# so RFC 9727 / MCP / Agent Skills scanners parse them as JSON/JWKS.
# ─────────────────────────────────────────────────────────────────

/.well-known/api-catalog
  Content-Type: application/linkset+json; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  Access-Control-Allow-Origin: *

/.well-known/mcp/server-card.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  Access-Control-Allow-Origin: *

/.well-known/agent-skills/index.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  Access-Control-Allow-Origin: *

/.well-known/http-message-signatures-directory
  Content-Type: application/http-message-signatures-directory; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  Access-Control-Allow-Origin: *

/.well-known/openid-configuration
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  Access-Control-Allow-Origin: *

/.well-known/oauth-authorization-server
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  Access-Control-Allow-Origin: *

/.well-known/oauth-protected-resource
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  Access-Control-Allow-Origin: *

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-DNS-Prefetch-Control: on
  X-Commercial-License: https://holdlens.com/api-terms
  Link: <https://holdlens.com/api-terms>; rel="license", </.well-known/api-catalog>; rel="api-catalog"; type="application/linkset+json", </api>; rel="service-doc"; type="text/html", </api/v1/index.json>; rel="service-desc"; type="application/json", </.well-known/mcp/server-card.json>; rel="mcp-server-card"; type="application/json", </.well-known/agent-skills/index.json>; rel="agent-skills"; type="application/json", </llms.txt>; rel="llms"; type="text/plain"
