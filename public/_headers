# HoldLens — Cloudflare Pages _headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/
#
# PPC tier taxonomy (X-API-Tier + X-PPC-Suggested-Price):
#   free-core           $0.001 / crawl   — stable endpoints (managers, scores, rotation)
#   paid-daily          $0.010 / crawl   — daily.json, movers.json (fresh each trading day)
#   paid-premium        $0.005 / crawl   — derived analytics (consensus, crowded, contrarian)
#   paid-training       $0.005 / crawl   — structured catalog + manifest (index.json)
# These headers are hints — actual billing configured per-route in Cloudflare
# AI Crawl Control → Pay-Per-Crawl (operator-gated, payment required).

# ─────────────────────────────────────────────────────────────────
# Daily-fresh endpoints — premium PPC tier, short cache so bots re-crawl
# every trading day + SEO crawlers treat as legitimate freshness signal
# ─────────────────────────────────────────────────────────────────

/api/v1/daily.json
  Cache-Control: public, max-age=300, s-maxage=300, stale-while-revalidate=3600
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, HEAD, OPTIONS
  X-Commercial-License: https://holdlens.com/api-terms
  X-API-Tier: paid-daily
  X-PPC-Suggested-Price: 0.010
  X-Content-Revision: daily-eod
  X-AI-Integration-Contact: https://holdlens.com/for-ai
  X-Attribution-Required: cite holdlens.com
  Link: <https://holdlens.com/api-terms>; rel="license", <https://holdlens.com/for-ai>; rel="help"

/api/v1/movers.json
  Cache-Control: public, max-age=300, s-maxage=300, stale-while-revalidate=3600
