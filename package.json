    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "satori": "^0.26.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
