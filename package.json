{
  "name": "holdlens",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "generate-og": "npx tsx scripts/generate-og-images.ts",
    "fetch-edgar": "npx tsx scripts/fetch-edgar-13f.ts",
    "generate-api": "npx tsx scripts/generate-api-json.ts",
    "prebuild": "npx tsx scripts/generate-og-images.ts && npx tsx scripts/generate-api-json.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "indexnow": "npx tsx scripts/ping-indexnow.ts",
